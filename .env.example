# ──────────────────────────────────────────────────────────────────────────────
# QR Menu SaaS — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Lines starting with # are comments and are ignored.
# PRODUCTION değerleri ile DEV değerleri farklı olduğunda yorum satırında belirtilmiştir.
# ──────────────────────────────────────────────────────────────────────────────

# ── Uygulama ──────────────────────────────────────────────────────────────────
APP_NAME="KentApp"
APP_ENV=local                        # production | staging | local
APP_KEY=                             # php artisan key:generate ile üret
APP_DEBUG=true                       # PRODUCTION: false
APP_URL=http://localhost             # PRODUCTION: https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# ── Şifreleme ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12                     # PRODUCTION: 12 veya daha yüksek

# ── Loglama ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single                     # PRODUCTION: daily veya papertrail
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                      # PRODUCTION: error

# ── Veritabanı ────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kentapp
DB_USERNAME=root
DB_PASSWORD=

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_DRIVER=database              # PRODUCTION: redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false                # PRODUCTION: true
SESSION_PATH=/
SESSION_DOMAIN=null                  # PRODUCTION: .yourdomain.com
SESSION_SECURE_COOKIE=false          # PRODUCTION: true (HTTPS zorunlu)
SESSION_SAME_SITE=lax

# ── Cache / Queue / Broadcasting ──────────────────────────────────────────────
CACHE_STORE=database                 # PRODUCTION: redis
QUEUE_CONNECTION=database            # PRODUCTION: redis
BROADCAST_CONNECTION=log             # PRODUCTION: pusher | reverb

# ── Dosya Depolama ────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local                # PRODUCTION: s3

# ── Redis ─────────────────────────────────────────────────────────────────────
# phpredis extension yoksa REDIS_CLIENT=predis (composer require predis/predis)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# REDIS_DB=0
# REDIS_CACHE_DB=1

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log                      # PRODUCTION: smtp | ses | postmark | resend
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AWS S3 (Medya depolama için) ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Localization ──────────────────────────────────────────────────────────────
# Desteklenen diller virgülle ayrılmış (config/app.php'de okunur)
SUPPORTED_LOCALES=en,tr
DEFAULT_LOCALE=en

# ── Ödeme — Stripe ────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_KEY=pk_test_...               # PRODUCTION: pk_live_...
STRIPE_SECRET=sk_test_...            # PRODUCTION: sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...      # Stripe Dashboard → Webhooks → Signing Secret

# ── Ödeme — İyzico ────────────────────────────────────────────────────────────
# Dashboard: https://merchant.iyzipay.com
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox.iyzipay.com   # PRODUCTION: https://api.iyzipay.com

# ── AI — OpenAI ───────────────────────────────────────────────────────────────
# Dashboard: https://platform.openai.com/api-keys

# ── Laravel Telescope ─────────────────────────────────────────────────────────
# PRODUCTION ortamında false yaparak Telescope'u kapat
TELESCOPE_ENABLED=true               # PRODUCTION: false

# ── Vite ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
