#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────────────────────
# QR Menu — Git Pre-commit Hook
# Kurulum: composer install-hooks
# ──────────────────────────────────────────────────────────────────────────────

set -e

PHP="php"
VENDOR_BIN="vendor/bin"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo ""
echo "🔍 Pre-commit kontrolleri çalışıyor..."
echo "────────────────────────────────────────"

# ── 1. PHP Syntax Kontrolü ────────────────────────────────────────────────────
echo -e "${YELLOW}[1/4] PHP syntax kontrolü...${NC}"

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.php$' || true)

if [ -n "$STAGED" ]; then
    SYNTAX_ERRORS=0
    while IFS= read -r FILE; do
        if ! $PHP -l "$FILE" > /dev/null 2>&1; then
            echo -e "${RED}  ✗ Syntax hatası: $FILE${NC}"
            $PHP -l "$FILE"
            SYNTAX_ERRORS=1
        fi
    done <<< "$STAGED"

    if [ $SYNTAX_ERRORS -ne 0 ]; then
        echo -e "${RED}✗ Syntax hatası bulundu. Commit iptal edildi.${NC}"
        exit 1
    fi
    echo -e "${GREEN}  ✓ Syntax temiz${NC}"
else
    echo "  → Staged PHP dosyası yok, atlanıyor."
fi

# ── 2. PHP CS Fixer ───────────────────────────────────────────────────────────
echo -e "${YELLOW}[2/4] Kod stili kontrolü (PHP CS Fixer)...${NC}"

if [ -f "$VENDOR_BIN/php-cs-fixer" ]; then
    if ! $PHP $VENDOR_BIN/php-cs-fixer fix --dry-run --diff --quiet 2>/dev/null; then
        echo -e "${RED}  ✗ Stil hataları bulundu.${NC}"
        echo "  Düzeltmek için: composer cs-fix"
        echo -e "${RED}✗ Commit iptal edildi.${NC}"
        exit 1
    fi
    echo -e "${GREEN}  ✓ Kod stili temiz${NC}"
else
    echo -e "${YELLOW}  ⚠ php-cs-fixer bulunamadı, atlanıyor (composer install çalıştır)${NC}"
fi

# ── 3. PHPStan Statik Analiz ──────────────────────────────────────────────────
echo -e "${YELLOW}[3/4] Statik analiz (PHPStan)...${NC}"

if [ -f "$VENDOR_BIN/phpstan" ]; then
    if ! $PHP $VENDOR_BIN/phpstan analyse --no-progress --memory-limit=512M 2>/dev/null; then
        echo -e "${RED}  ✗ PHPStan hataları bulundu.${NC}"
        echo "  Detay için: composer analyse"
        echo -e "${RED}✗ Commit iptal edildi.${NC}"
        exit 1
    fi
    echo -e "${GREEN}  ✓ Statik analiz temiz${NC}"
else
    echo -e "${YELLOW}  ⚠ phpstan bulunamadı, atlanıyor${NC}"
fi

# ── 4. Unit Testler ───────────────────────────────────────────────────────────
echo -e "${YELLOW}[4/4] Unit testler...${NC}"

if [ -f "$VENDOR_BIN/phpunit" ]; then
    if ! $PHP $VENDOR_BIN/phpunit --testsuite=Unit --no-coverage --no-progress 2>/dev/null; then
        echo -e "${RED}  ✗ Unit testler başarısız.${NC}"
        echo "  Detay için: composer test"
        echo -e "${RED}✗ Commit iptal edildi.${NC}"
        exit 1
    fi
    echo -e "${GREEN}  ✓ Unit testler geçti${NC}"
else
    echo -e "${YELLOW}  ⚠ phpunit bulunamadı, atlanıyor${NC}"
fi

echo "────────────────────────────────────────"
echo -e "${GREEN}✓ Tüm kontroller geçti. Commit devam ediyor...${NC}"
echo ""
